# OpenAI (chat agent + Excel row normalizer)
OPENAI_API_KEY=
# Optional overrides — defaults are set in code (chat.js / bulkImport.js).
# Check https://platform.openai.com/docs/models for current model IDs.
OPENAI_CHAT_MODEL=gpt-5.6-terra
OPENAI_BULK_MODEL=gpt-5.6-luna

# Postgres — Supabase or Neon connection string
DATABASE_URL=postgres://user:pass@host:5432/dbname

# 32-byte hex key for encrypting Karix tokens at rest.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=

# Protects /api/admin/* (token encryption + the in-app "Setup WABA connection"
# panel). Make this a real random string — anyone with it can write
# encrypted Karix tokens into your database.
ADMIN_SETUP_SECRET=

# Dev-only auth stand-in — fallback only. Once you connect a WABA account via
# the in-app Setup panel, the browser sends x-org-id/x-user-id automatically
# and these are unused. Only needed for testing the API directly (curl/Postman).
DEV_ORG_ID=
DEV_USER_ID=

PORT=3000
