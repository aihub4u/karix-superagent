# OpenAI (chat agent + Excel row normalizer)
OPENAI_API_KEY=
# Optional overrides — defaults are set in code (chat.js / bulkImport.js).
# Check https://platform.openai.com/docs/models for current model IDs.
OPENAI_CHAT_MODEL=gpt-5.6-terra
OPENAI_BULK_MODEL=gpt-5.6-luna

# Postgres — Supabase or Neon connection string
DATABASE_URL=postgres://user:pass@host:5432/dbname

# 32-byte hex key for encrypting Karix tokens at rest.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=

# Dev-only auth stand-in (remove once real auth/session middleware is wired up)
DEV_ORG_ID=
DEV_USER_ID=

PORT=3000
